<screen>
	<styles>
		<style name="style_main" bg_color="0xf1ece6" />
		<style name="wifi_icon" arc_color="0xece3dc" arc_opa="255" arc_width="8" bg_opa="0" arc_rounded="true" />
	</styles>

	<view width="320" height="240" align="center">
		<!-- Outer arc -->
		<lv_arc width="150" height="150" align="center" y="5" start_angle="200" end_angle="340">
			<style name="wifi_icon" />
		</lv_arc>

		<!-- Middle arc -->
		<lv_arc width="90" height="90" align="center" y="5" start_angle="200" end_angle="340">
			<style name="wifi_icon" />
		</lv_arc>

		<!-- Inner arc -->
		<lv_arc width="40" height="40" align="center" y="20" start_angle="200" end_angle="340">
			<style name="wifi_icon" />
		</lv_arc>

		<lv_label
			text="WiFi not found!"
			style_text_font="Poppins_bold_28"
			style_bg_color="0xf1ece6"
			style_align="center"
			style_text_color="0x3e3121"
		/>

		<lv_label
			text="Open EspTouch to configure WiFI"
			style_text_font="Poppins_regular_14"
			style_bg_color="0xf1ece6"
			style_align="center"
			style_text_color="0x3e3121"
			y="20"
		/>
	</view>
</screen>
