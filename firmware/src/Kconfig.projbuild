menu "Sdrumo Application"

    config SDRUMO_API_BASE_URL
        string "Sdrumo API base URL"
        default "https://api.sdrumo.example"
        help
            Base URL of the Sdrumo backend (no trailing slash).

    config SDRUMO_USE_HTTPS
        bool "Use HTTPS for API calls"
        default y
        help
            Enable TLS via mbedTLS. Disable only for LAN/development.

    config SDRUMO_API_TIMEOUT_MS
        int "API request timeout (ms)"
        default 5000
        range 1000 30000

    config SDRUMO_API_MAX_RETRIES
        int "Max retries on transient API failure"
        default 3
        range 0 10

    config SDRUMO_API_RESP_BUF_SIZE
        int "HTTP response buffer size (bytes)"
        default 8192
        range 1024 16384

endmenu
